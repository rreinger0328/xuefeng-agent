# 雪峰Agent 配置文件
# 复制此文件为 .env，填入你的 API Key
# cp .env.example .env

# ── 必填 ──
# DeepSeek API Key（推荐，便宜好用）
# 获取地址：https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-your-api-key-here

# ── 可选（以下均有默认值）──
# API 地址（默认 DeepSeek，可换任何 OpenAI 兼容 API）
LLM_BASE_URL=https://api.deepseek.com

# 模型名称
LLM_MODEL=deepseek-chat

# Tavily 联网搜索 Key（强烈推荐，免费额度每月 1000 次）
# 获取地址：https://tavily.com → Get Started → 复制 tvly- 开头的 Key
TAVILY_KEY=tvly-your-key-here
